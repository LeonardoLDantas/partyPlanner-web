{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "partyplanner-web: dev server",
      "type": "npm",
      "script": "dev",
      "path": "",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*Local:.*http://localhost:5173.*"
        }
      }
    }
  ]
}
